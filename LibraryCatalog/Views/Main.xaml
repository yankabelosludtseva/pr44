<Page x:Class="LibraryCatalog.Views.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:items="clr-namespace:LibraryCatalog.Views.Items"
      mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800" Title="Каталог">

    <Grid>
        <!-- ListView растягивается на всю ширину, горизонтальный скролл отключен -->
        <ListView ItemsSource="{Binding Books}" 
                  HorizontalAlignment="Stretch" Margin="0,0,0,45"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <!-- Сти контейнера: заставляет каждый элемент занимать 100% ширины ListView -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="4,3"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <!-- Подключаем UserControl для отображения одной книги -->
                    <items:BookItem DataContext="{Binding}" HorizontalAlignment="Stretch"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Кнопка добавления новой записи -->
        <Button Content="Добавить" Height="28" Width="80"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,10,10" Command="{Binding OnAddBook}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FF2D89D6"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Page>