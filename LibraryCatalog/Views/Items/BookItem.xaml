<UserControl x:Class="LibraryCatalog.Views.Items.BookItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             FontFamily="Bahnschrift Light Condensed">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="UpdateButton">
            <Setter Property="Background" Value="#FF43A047"/>
            <Setter Property="BorderBrush" Value="#FF43A047"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Button" x:Key="DeleteButton">
            <Setter Property="Background" Value="#FFE53935"/>
            <Setter Property="BorderBrush" Value="#FFE53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Button" x:Key="StatusButton">
            <Setter Property="Background" Value="#FF9C27B0"/>
            <Setter Property="BorderBrush" Value="#FF9C27B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBox" x:Key="StyledTextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <!-- Основной контейнер с тенью -->
    <Grid Margin="10" Background="White" HorizontalAlignment="Stretch">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
        </Grid.Effect>

        <!-- Иконка книги -->
        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"
               Source="/Image/ic-book.png"/>

        <!-- Основной контент -->
        <Grid Margin="60, 0, 0, 0" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: Название и Автор -->
            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White" HorizontalAlignment="Stretch">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1" BlurRadius="3" ShadowDepth="1"/>
                </Grid.Effect>
                <Label Content="Название:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Title}"
                         IsEnabled="{Binding IsEditMode}"
                         Style="{StaticResource StyledTextBox}"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid Margin="10, 80, 10, 0" Height="60" VerticalAlignment="Top" Background="White" HorizontalAlignment="Stretch">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1" BlurRadius="3" ShadowDepth="1"/>
                </Grid.Effect>
                <Label Content="Автор:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Author}"
                         IsEnabled="{Binding IsEditMode}"
                         Style="{StaticResource StyledTextBox}"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Правая колонка: Год и Жанр -->
            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1" HorizontalAlignment="Stretch">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1" BlurRadius="3" ShadowDepth="1"/>
                </Grid.Effect>
                <Label Content="Год издания:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Year}"
                         IsEnabled="{Binding IsEditMode}"
                         Style="{StaticResource StyledTextBox}"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1" HorizontalAlignment="Stretch">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1" BlurRadius="3" ShadowDepth="1"/>
                </Grid.Effect>
                <Label Content="Жанр:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Genre}"
                         IsEnabled="{Binding IsEditMode}"
                         Style="{StaticResource StyledTextBox}"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Описание (на всю ширину) -->
            <Grid Margin="10,150,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.ColumnSpan="2" HorizontalAlignment="Stretch">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1" BlurRadius="3" ShadowDepth="1"/>
                </Grid.Effect>
                <Label Content="Описание:" VerticalAlignment="Top" Margin="10, 0, 10, 0"/>
                <TextBox Text="{Binding Description}"
                         IsEnabled="{Binding IsEditMode}"
                         Style="{StaticResource StyledTextBox}"
                         Margin="10, 25, 10, 0"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Кнопки управления -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="0,220,10,0" Grid.Column="1">

                <!-- Кнопка Удалить -->
                <Button Style="{StaticResource DeleteButton}"
                        Command="{Binding OnDelete}"
                        Content="Удалить"
                        Height="28" Width="80" Margin="0,0,8,0">
                    <Button.Effect>
                        <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="2"/>
                    </Button.Effect>
                </Button>

                <!-- Кнопка Статус (В наличии/Выдана) -->
                <Button Style="{StaticResource StatusButton}"
                        Command="{Binding OnToggleStatus}"
                        Content="{Binding StatusText}"
                        Height="28" Width="90" Margin="0,0,8,0">
                    <Button.Effect>
                        <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="2"/>
                    </Button.Effect>
                </Button>

                <!-- Кнопка Изменить/Сохранить -->
                <Button Style="{StaticResource UpdateButton}"
                        Command="{Binding OnEdit}"
                        Content="{Binding EditButtonText}"
                        Height="28" Width="80">
                    <Button.Effect>
                        <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="2"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>